# Preferred chat model for the chat route (app/api/chat/route.ts).
AZURE_API_KEY=
AZURE_RESOURCE_NAME=
AZURE_CHAT_DEPLOYMENT=
AZURE_EMBEDDING_DEPLOYMENT=

# Optional fallback chat model for the chat route.
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Absolute site URL used for metadata / Open Graph tags. Optional in dev.
# NEXT_PUBLIC_SITE_URL=https://example.com

# Optional sub-path when served behind a reverse proxy, e.g. /catalog.
# NEXT_PUBLIC_BASE_PATH=

# Optional PostHog analytics. Browser traffic is proxied through /ph.
NEXT_PUBLIC_POSTHOG_KEY=

# Vercel Blob (private store catalog-ai-viewer-blob / store_NnU2oYebKkBF6moT)
BLOB_READ_WRITE_TOKEN=
# Supabase, Hetzner self-hosted
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Admin area
ADMIN_PASSWORD=
ADMIN_SECRET=
